   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. Extract Year and Month Name from data\n",
    "transactions[\"Year\"] = transactions[\"date\"].dt.year\n",
    "transactions[\"Month\"] = transactions[\"date\"].dt.strftime(\"%b\")\n",
    "\n",
    "# 2. Calculate the fraud rate per year/month combination\n",
    "heatmap_data = (\n",
    "    transactions.groupby([\"Year\", \"Month\"])[\"is_fraud\"]\n",
    "    .mean()\n",
    "    .reset_index()\n",
    ")\n",
    "heatmap_data[\"is_fraud\"] *= 100  # Convert to percentage\n",
    "\n",
    "# 3. Pivot the data into a Year x Month grid\n",
    "months_order = [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\", \"Jul\", \"Aug\", \"Sep\", \"Oct\", \"Nov\", \"Dec\"]\n",
    "pivot_df = heatmap_data.pivot(index=\"Year\", columns=\"Month\", values=\"is_fraud\")\n",
    "pivot_df = pivot_df[months_order]  # Ensure correct chronological order\n",
    "\n",
    "# 4. Plot the heatmap\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "sns.heatmap(\n",
    "    pivot_df, \n",
    "    cmap=\"Reds\", \n",
    "    annot=False,          # Set to True if you want the exact % numbers written in each box\n",
    "    fmt=\".2f\", \n",
    "    linewidths=0.5, \n",
    "    cbar_kws={'label': 'Fraud Rate (%)'},\n",
    "    ax=ax\n",
    ")\n",
    "\n",
    "ax.set_title(\"Fraud Rate Heatmap: Months vs. Years\", fontsize=14, pad=15)\n",
    "ax.set_xlabel(\"Month / Season\", fontsize=12)\n",
    "ax.set_ylabel(\"Year\", fontsize=12)\n",
    "\n",
    "fig.tight_layout()\n",
    "fig.savefig(FIGURE_DIR / \"eda_monthly_fraud_trend.png\", dpi=160, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
  },
