    "ax.set_ylabel(\"Absolute amount clipped at sample 99th percentile\")\n",
    "ax.legend(title=\"Fraud label\", labels=[\"Non-fraud\", \"Fraud\"])\n",
    "fig.tight_layout()\n",
    "fig.savefig(FIGURE_DIR / \"eda_amount_vs_hour_scatter.png\", dpi=160, bbox_inches=\"tight\")\n",
    "plt.show()\n"
   ]
